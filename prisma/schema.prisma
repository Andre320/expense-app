// Multi-user Postgres schema for expense & financial planning

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionKind {
  INCOME
  EXPENSE
}

enum SavingsMovementKind {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
  INITIAL
}

enum RsuVestStatus {
  PENDING
  RECEIVED
}

// --- Auth.js models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  appSettings    AppSettings?
  incomeProfiles IncomeProfile[]
  incomeBonuses  IncomeBonus[]
  categories     Category[]
  knownStores    KnownStore[]
  tags           Tag[]
  transactions   Transaction[]
  savingsGoals   SavingsGoal[]
  savingsAccounts SavingsAccount[]
  rsuPlans       RsuPlan[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// --- App domain ---

model AppSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Saved salary profile for Income tab (gross input amount in crSalaryCurrency)
  crSalaryGross    Decimal @default(0)
  crSalaryCurrency String  @default("CRC")
  crPayPeriod      String  @default("MONTHLY")

  /// CRC per 1 USD — used by Income planner (gross in USD) and saving net to USD base.
  crCrcPerUsd Decimal @default(505)
  /// % of gross (0–100) — Asociación Solidarista
  crSolidaristaPct Decimal @default(0)
  /// % of gross — Plan de pensiones complementarias
  crPensionComplementariaPct Decimal @default(0)
  /// % of gross — e.g. plan acciones / descuento nómina (ESPP)
  crEsppPct Decimal @default(0)

  updatedAt DateTime @updatedAt
}

/// Dated salary profile — supports promotions and historical planning accuracy.
model IncomeProfile {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label         String   @default("Salary")
  effectiveFrom DateTime
  /// null = open-ended (current)
  effectiveTo   DateTime?

  crSalaryGross    Decimal
  crSalaryCurrency String  @default("CRC")
  crPayPeriod      String  @default("MONTHLY")
  crSolidaristaPct Decimal @default(0)
  crPensionComplementariaPct Decimal @default(0)
  crEsppPct Decimal @default(0)

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, effectiveFrom])
}

/// Gross bonus paid on a date (combined with salary for CCSS, renta, Solidarista, ESPP).
model IncomeBonus {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  grossAmount       Decimal
  grossCurrency     String   @default("CRC")
  paidOn            DateTime @db.Date
  repeatsAnnually   Boolean  @default(false)
  position          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([userId, paidOn])
}

model Category {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  kind         TransactionKind
  color        String?           @default("#6366f1")
  position     Int               @default(0)
  transactions Transaction[]
  knownStores  KnownStore[]

  @@unique([userId, name, kind])
  @@index([userId])
}

/// Map messy bank merchant text (substring match) to a clean label + category.
model KnownStore {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern     String
  displayName String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([pattern])
}

model Tag {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  occurredAt  DateTime
  kind        TransactionKind
  description String            @default("")
  categoryId  String?
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  amountOriginal Decimal
  currencyCode   String
  /// Units of base per 1 unit of original (multiply by amountOriginal → base)
  rateToBase     Decimal
  amountBase     Decimal
  /// Units of quote per 1 unit of original
  rateToQuote    Decimal
  amountQuote    Decimal

  tags TransactionTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([occurredAt])
  @@index([kind])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model SavingsGoal {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  /// CRC or USD — amounts below are stored in this currency.
  currency       String   @default("CRC")
  targetAmount   Decimal? @map("targetBase")
  currentAmount  Decimal  @default(0) @map("balanceBase")
  color          String?  @default("#22c55e")
  notes          String?
  priorityOrder  Int      @default(0) @map("position")
  movements      SavingsGoalMovement[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model SavingsGoalMovement {
  id          String              @id @default(cuid())
  goalId      String
  goal        SavingsGoal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  kind        SavingsMovementKind
  amount      Decimal
  description String              @default("")
  occurredAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())

  @@index([goalId])
  @@index([occurredAt])
}

/// Real savings account (bank, wallet) — balance in `currency`.
model SavingsAccount {
  id        String                   @id @default(cuid())
  userId    String
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  /// CRC or USD — balance is stored in this currency.
  currency  String                   @default("CRC")
  balance   Decimal                  @default(0)
  notes     String?
  position  Int                      @default(0)
  movements SavingsAccountMovement[]
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@index([userId])
}

model SavingsAccountMovement {
  id          String              @id @default(cuid())
  accountId   String
  account     SavingsAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  kind        SavingsMovementKind
  amount      Decimal
  description String              @default("")
  occurredAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())

  @@index([accountId])
  @@index([occurredAt])
}

/// RSU grant plan — fixed share count vested on a recurring schedule.
model RsuPlan {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  ticker               String
  totalShares          Decimal
  grantDate            DateTime
  vestingPeriodMonths  Int       @default(48)
  vestIntervalMonths   Int       @default(3)
  vestDayOfMonth       Int       @default(20)
  taxWithholdPct       Decimal   @default(20)
  notes                String?
  position             Int       @default(0)
  vests                RsuVest[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
}

model RsuVest {
  id              String        @id @default(cuid())
  planId          String
  plan            RsuPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  sequence        Int
  scheduledDate   DateTime
  shares          Decimal
  status          RsuVestStatus @default(PENDING)
  receivedAt      DateTime?
  sharesWithheld  Decimal?
  netShares       Decimal?
  cashBonusUsd    Decimal?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([planId, sequence])
  @@index([planId])
  @@index([scheduledDate])
}
