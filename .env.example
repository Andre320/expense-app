# Postgres connection (local: docker compose up -d)
DATABASE_URL="postgresql://expense:expense@localhost:5432/expense_app?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Required in production
# AUTH_URL=https://your-domain.com

# Alpaca paper or live trading keys (same keys work for Market Data API quotes)
# Create keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Optional: default ticker on the Stocks page (defaults to SNOW)
# NEXT_PUBLIC_DEFAULT_STOCK_TICKER=SNOW
# Optional: iex (free tier default), sip, delayed_sip, etc.
# ALPACA_DATA_FEED=iex
